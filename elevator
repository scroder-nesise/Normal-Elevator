        sub.TextXAlignment = Enum.TextXAlignment.Left; sub.Parent = row
    end

    local toggled = defaultVal or false

    local track = Instance.new("Frame")
    track.Size             = UDim2.new(0, 32, 0, 18)
    track.Position         = UDim2.new(1, -44, 0.5, -9)
    track.BackgroundColor3 = toggled and Color3.fromRGB(50, 35, 120) or Color3.fromRGB(30, 34, 48)
    track.BorderSizePixel  = 0
    track.Parent           = row
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
    local ts = Instance.new("UIStroke", track)
    ts.Color = toggled and Color3.fromRGB(108, 92, 231) or Color3.fromRGB(42, 47, 66); ts.Thickness = 1

    local thumb = Instance.new("Frame")
    thumb.Size             = UDim2.new(0, 10, 0, 10)
    thumb.Position         = toggled and UDim2.new(0, 18, 0.5, -5) or UDim2.new(0, 4, 0.5, -5)
    thumb.BackgroundColor3 = toggled and Color3.fromRGB(162, 155, 254) or Color3.fromRGB(58, 63, 85)
    thumb.BorderSizePixel  = 0
    thumb.Parent           = track
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0); btn.BackgroundTransparency = 1
    btn.Text = ""; btn.Parent = row

    btn.MouseButton1Click:Connect(function()
        toggled = not toggled
        track.BackgroundColor3 = toggled and Color3.fromRGB(50, 35, 120) or Color3.fromRGB(30, 34, 48)
        ts.Color               = toggled and Color3.fromRGB(108, 92, 231) or Color3.fromRGB(42, 47, 66)
        thumb.Position         = toggled and UDim2.new(0, 18, 0.5, -5) or UDim2.new(0, 4, 0.5, -5)
        thumb.BackgroundColor3 = toggled and Color3.fromRGB(162, 155, 254) or Color3.fromRGB(58, 63, 85)
        if callback then callback(toggled) end
    end)

    return row
end

