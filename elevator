local logLayout = Instance.new("UIListLayout", logBox)
logLayout.SortOrder = Enum.SortOrder.LayoutOrder
logLayout.Padding   = UDim.new(0, 0)

local logOrder = 0

local function RefreshLog()
    for _, c in ipairs(logBox:GetChildren()) do
        if c:IsA("TextLabel") then c:Destroy() end
    end
    logOrder = 0
    local colorMap = {
        ok      = Color3.fromRGB(82,  201, 122),
        warn    = Color3.fromRGB(224, 180, 82),
        err     = Color3.fromRGB(224, 82,  82),
        default = Color3.fromRGB(74,  80,  104),
    }
    for _, entry in ipairs(LogLines) do
        logOrder += 1
        local line = Instance.new("TextLabel")
        line.Text                   = string.format("[%s] %s", entry.time, entry.msg)
        line.Font                   = Enum.Font.Code
        line.TextSize               = 10
        line.TextColor3             = colorMap[entry.color] or colorMap.default
        line.BackgroundTransparency = 1
        line.Size                   = UDim2.new(1, -16, 0, 16)
        line.Position               = UDim2.new(0, 8, 0, 0)
        line.TextXAlignment         = Enum.TextXAlignment.Left
        line.LayoutOrder            = logOrder
        line.Parent                 = logBox
    end
    logBox.CanvasSize     = UDim2.new(0, 0, 0, logOrder * 16 + 4)
    logBox.CanvasPosition = Vector2.new(0, math.max(0, logOrder * 16 - 100))
end

MakeButton(StatsP, "Clear Log", 366, "primary", function()
    LogLines = {}
    AddLog("Log cleared")
    RefreshLog()
end)

