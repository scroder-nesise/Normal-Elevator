-- Stage display + clock
local stageNames = {
    "Waiting...", "Voting...", "Loading Floor...",
    "Riding Elevator", "Floor Active", "Collecting Coins",
    "Floor Complete", "Returning...",
}
local stageIdx = 1

AddConnection(RunService.Heartbeat:Connect(function()
    local elapsed = math.floor(tick() - Stats.SessionStart)
    local m = math.floor(elapsed / 60)
    local s = elapsed % 60
    statLabels["s_time"].Text = string.format("%d:%02d", m, s)

    if Settings.AutoRide then
        stageValL.Text       = Stats.NextFloorStage
        stageValL.TextColor3 = Color3.fromRGB(82, 201, 122)
    else
        stageValL.Text       = "Waiting..."
        stageValL.TextColor3 = Color3.fromRGB(162, 155, 254)
    end
end))

-- Simulated farm ticker
local lastFarmTick = tick()
AddConnection(RunService.Heartbeat:Connect(function()
    if Settings.AutoRide and tick() - lastFarmTick >= 1.8 then
        lastFarmTick = tick()
        Stats.FloorsCompleted += 1
        Stats.CoinsFarmed     += math.random(2, 9)
        statLabels["s_floors"].Text = tostring(Stats.FloorsCompleted)
        statLabels["s_coins"].Text  = tostring(Stats.CoinsFarmed)
        stageIdx             = (stageIdx % #stageNames) + 1
        Stats.NextFloorStage = stageNames[stageIdx]
        RefreshLog()
    end
end))

-- Death tracking
AddConnection(Humanoid.Died:Connect(function()
    Stats.Deaths += 1
    statLabels["s_deaths"].Text = tostring(Stats.Deaths)
    AddLog("Character died", "err")
    RefreshLog()
end))

-- Log throttle
local lastLogRefresh = tick()
AddConnection(RunService.Heartbeat:Connect(function()
    if tick() - lastLogRefresh >= 0.5 then
        lastLogRefresh = tick()
        RefreshLog()
    end
end))

-- Respawn handler
AddConnection(LocalPlayer.CharacterAdded:Connect(function(newChar)
    Character = newChar
    Humanoid  = newChar:WaitForChild("Humanoid")
    RootPart  = newChar:WaitForChild("HumanoidRootPart")
    Humanoid.WalkSpeed = Settings.WalkSpeed
    Humanoid.JumpPower = Settings.JumpPower
    AddConnection(Humanoid.Died:Connect(function()
        Stats.Deaths += 1
        statLabels["s_deaths"].Text = tostring(Stats.Deaths)
        AddLog("Character died", "err")
        RefreshLog()
    end))
end))

