-- ============================================================

-- Safely get a CFrame from a path, returns nil if not found
local function SafeGet(...)
    local obj = workspace
    for _, key in ipairs({...}) do
        if obj then
            obj = obj:FindFirstChild(key)
        end
    end
    return obj
end

local function TeleportTo(cframe, offsetY)
    offsetY = offsetY or 3
    if RootPart then
        RootPart.CFrame = cframe * CFrame.new(0, offsetY, 0)
    end
end

-- Goto Elevator:
--   Primary:  workspace.Lobby.Elevator.Trigger
--   Fallback: search workspace for any Part named "Trigger" inside "Elevator"
local function GotoElevator()
    -- Primary path (confirmed from existing scripts)
    local trigger = SafeGet("Lobby", "Elevator", "Trigger")
    if trigger and trigger:IsA("BasePart") then
        TeleportTo(trigger.CFrame)
        AddLog("Teleported → Elevator", "ok")
        return
    end

    -- Fallback 1: any Model named "Elevator" anywhere in workspace
    local function FindElevator(parent)
        for _, child in ipairs(parent:GetChildren()) do
            if child.Name == "Elevator" and child:IsA("Model") then
                local pf = child:FindFirstChild("Trigger") or child:FindFirstChildWhichIsA("BasePart")
                if pf then return pf end
            end
            local found = FindElevator(child)
            if found then return found end
        end
    end
    local elevPart = FindElevator(workspace)
    if elevPart and elevPart:IsA("BasePart") then
        TeleportTo(elevPart.CFrame)
        AddLog("Teleported → Elevator (fallback)", "ok")
        return
    end

    AddLog("ERR: Elevator not found in workspace", "err")
end

-- Goto Lobby:
--   Primary:  workspace.Lobby.SpawnLocation  (or just the Lobby model's PrimaryPart)
--   Fallback: workspace SpawnLocation
local function GotoLobby()
    -- Primary: SpawnLocation inside Lobby model
    local spawnInLobby = SafeGet("Lobby", "SpawnLocation")
    if spawnInLobby and spawnInLobby:IsA("BasePart") then
        TeleportTo(spawnInLobby.CFrame)
        AddLog("Teleported → Lobby", "ok")
        return
    end

    -- Fallback 1: PrimaryPart of Lobby model
    local lobby = workspace:FindFirstChild("Lobby")
    if lobby and lobby:IsA("Model") and lobby.PrimaryPart then
        TeleportTo(lobby.PrimaryPart.CFrame)
        AddLog("Teleported → Lobby (PrimaryPart)", "ok")
        return
    end

    -- Fallback 2: any BasePart named "SpawnLocation" in workspace
    local anySpawn = workspace:FindFirstChild("SpawnLocation", true)
    if anySpawn and anySpawn:IsA("BasePart") then
        TeleportTo(anySpawn.CFrame)
        AddLog("Teleported → SpawnLocation (fallback)", "ok")
        return
    end

    AddLog("ERR: Lobby not found in workspace", "err")
end

